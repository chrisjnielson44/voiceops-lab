# =============================================================================
# VoiceOps Lab backend — environment configuration
# -----------------------------------------------------------------------------
# Copy to `.env` (gitignored). Shares the database + local model server with the
# rest of the stack. Auth lives in the standalone Better Auth server
# (../auth-server); this service introspects the forwarded session cookie against
# it (AUTH_SERVER_URL) to authenticate protected routes.
# =============================================================================

# --- Database (Neon Postgres) -----------------------------------------------
# Uses the UNPOOLED/direct URL (asyncpg + PgBouncer transaction pooling clash).
DATABASE_URL=
DATABASE_URL_UNPOOLED=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# --- Local model (real agent runtime) ---------------------------------------
# MLX LM (preferred):  mlx_lm.server --model mlx-community/Qwen2.5-7B-Instruct-4bit --port 8080
# Ollama also works:   LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1  LOCAL_LLM_MODEL=mistral:7b
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
LOCAL_LLM_API_KEY=mlx-local

# --- Hosted models (OpenRouter) ---------------------------------------------
# Set this and the curated cheap/fast catalog (app/providers/registry.py) auto-
# appears in the model picker — the recommended setup for a hosted deploy.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Set MLX_BASE_URL to advertise the local MLX provider in /api/providers.
MLX_BASE_URL=
MLX_API_KEY=mlx-local

# --- Voice (TTS/STT) — pluggable --------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Vercel Voice / AI Gateway realtime runtime. Prefer VERCEL_OIDC_TOKEN from
# `vercel env pull`; AI_GATEWAY_API_KEY is the manual/local fallback.
VERCEL_OIDC_TOKEN=
AI_GATEWAY_API_KEY=
VERCEL_VOICE_MODEL=openai/gpt-realtime-2

# --- Telephony — dialing hard-disabled while VOICEOPS_DEMO_MODE != "false" ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=voiceops-agent
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Runtime flags ----------------------------------------------------------
VOICEOPS_DEMO_MODE=true
VOICEOPS_PROMPT_VERSION=payer-ops-v4.0
# Call engine: "legacy" (hand-rolled loop) or "langgraph" (StateGraph engine
# with native interrupts + sub-agents). Both emit the identical SSE stream.
AGENT_ENGINE=legacy
# Tools requiring a human approval interrupt before they run (langgraph engine).
# Comma-separated, e.g. record_status,escalate. Empty = no approval gating.
AGENT_APPROVAL_TOOLS=

# --- LLM observability (Langfuse) -------------------------------------------
# Set both keys to trace every inference / tool / sub-agent / node. Self-hostable
# (point LANGFUSE_HOST at your box). Unset = tracing is a no-op (stays offline).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Service / auth boundary ------------------------------------------------
# Comma-separated CORS allowlist (the web SPA / auth-server origins in dev).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional shared secret an upstream proxy must send as x-internal-token.
BACKEND_INTERNAL_TOKEN=
# User id attributed to runs when no authenticated session is present.
DEMO_USER_ID=demo-user

# --- Session validation -----------------------------------------------------
# Better Auth host the backend introspects the session cookie against.
AUTH_SERVER_URL=http://127.0.0.1:3000
# Enforce a valid session on protected routes (set true in production).
REQUIRE_AUTH=false

# --- Observability ----------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
