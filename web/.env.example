# VoiceOps Lab — Vite SPA config. Copy to `.env` (or `.env.local`).

# --- Dev proxy targets (vite.config.ts) -------------------------------------
# /api/auth/* -> Next.js auth host (Better Auth); /api/* -> FastAPI backend.
VITE_AUTH_PROXY=http://127.0.0.1:3000
VITE_API_PROXY=http://127.0.0.1:8000

# --- Split-origin production auth (optional) --------------------------------
# Point the Better Auth client at a non-same-origin auth server.
VITE_AUTH_BASE_URL=

# --- Preview/screenshot bypass of the auth gate (DEV ONLY) ------------------
# Set to 1 so scripts/shots.mjs can render the cockpit without a running auth
# host. NEVER set this in a production build.
VITE_PREVIEW_BYPASS=
