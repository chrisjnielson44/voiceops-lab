{
  "name": "voiceops-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "VoiceOps Lab cockpit — Vite + React + TanStack SPA (talks to the FastAPI backend; Better Auth hosted by the standalone auth-server).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"e2e/**/*.{ts,tsx}\" \"scripts/**/*.{js,mjs}\" \"*.config.{ts,mjs}\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "audit": "npm audit --audit-level=moderate",
    "e2e": "playwright test",
    "shots": "node scripts/shots.mjs"
  },
  "dependencies": {
