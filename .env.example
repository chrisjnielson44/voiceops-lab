# =============================================================================
# VoiceOps Lab — environment configuration
# -----------------------------------------------------------------------------
# Copy to `.env.local` (gitignored) and fill in. The real agent runtime needs a
# local model server + a Postgres database for auth and call/ground-truth data.
# =============================================================================

# --- Auth (Better Auth) -----------------------------------------------------
# Generate a secret:  openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- Database (Neon Postgres) -----------------------------------------------
# App + migrations use the UNPOOLED/direct URL (node-postgres + PgBouncer).
DATABASE_URL=
DATABASE_URL_UNPOOLED=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# --- Local model (real agent runtime) ---------------------------------------
# MLX LM (preferred):  mlx_lm.server --model mlx-community/Qwen2.5-7B-Instruct-4bit --port 8080
# Ollama also works:   LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1  LOCAL_LLM_MODEL=mistral:7b
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
LOCAL_LLM_API_KEY=mlx-local

# --- Hosted models (OpenRouter) ---------------------------------------------
# Set this to expose the curated cheap/fast catalog in the model picker (the
# recommended setup for a deployed instance).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Voice (TTS/STT) — pluggable, for the LiveKit voice agent ---------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Vercel Voice / AI Gateway realtime runtime. Prefer VERCEL_OIDC_TOKEN from
# `vercel env pull`; AI_GATEWAY_API_KEY is the manual/local fallback.
VERCEL_OIDC_TOKEN=
AI_GATEWAY_API_KEY=
VERCEL_VOICE_MODEL=openai/gpt-realtime-2

# --- Telephony (real-number calling) — see /agent for the LiveKit agent ------
# DEMO SAFETY: dialing is hard-disabled while VOICEOPS_DEMO_MODE != "false".
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Runtime flags ----------------------------------------------------------
VOICEOPS_DEMO_MODE=true
VOICEOPS_PROMPT_VERSION=payer-ops-v4.0
