# LiveKit voice agent — copy to .env and fill in for real audio/telephony.

# LiveKit Cloud (from `lk cloud auth` / project settings)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Local model (shared with the web app)
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
LOCAL_LLM_API_KEY=mlx-local

# Same Neon DB the web app uses (ground-truth tools)
DATABASE_URL_UNPOOLED=

# STT/TTS providers (pick one set for real audio)
OPENAI_API_KEY=
# DEEPGRAM_API_KEY=
# CARTESIA_API_KEY=
# ELEVENLABS_API_KEY=
