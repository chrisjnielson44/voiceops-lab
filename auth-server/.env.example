# VoiceOps Lab — auth-server config. Copy to `.env` (or rely on the repo-root
# .env.local, which auth.mjs loads as a fallback).

# --- Better Auth ------------------------------------------------------------
# openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- Better Auth Dash (hosted dashboard) ------------------------------------
# The dash() plugin (ownership verification + monitoring) activates only when
# ALL THREE are set (from the Better Auth console). Leave blank locally to keep
# dash off; set them as deploy secrets to connect the hosted dashboard.
BETTER_AUTH_API_KEY=
BETTER_AUTH_API_URL=
BETTER_AUTH_KV_URL=

# --- Database (Neon Postgres) — UNPOOLED/direct URL -------------------------
DATABASE_URL_UNPOOLED=
DATABASE_URL=

# --- Service ----------------------------------------------------------------
AUTH_PORT=3000
# Origins allowed for direct (non-proxied) cross-origin auth calls + CSRF.
AUTH_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# --- Admin seed (npm run seed:admin) ----------------------------------------
# Public sign-up is disabled; this bootstraps the first admin + VoiceAdmin org/team.
# If ADMIN_PASSWORD is omitted, a random one is generated and printed once.
ADMIN_EMAIL=cjnielson44@gmail.com
ADMIN_NAME=Christopher Nielson
ADMIN_PASSWORD=
